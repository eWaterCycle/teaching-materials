    "data_budyko = data.loc[\"2014-01-01\":\"2025-01-01\"].copy()\n",
    "pre = data_budyko.loc[\"2014-01-01\":pre_end].copy()\n",
    "post = data_budyko.loc[post_start:\"2025-01-01\"].copy()\n",
    "full = data_budyko.copy()\n",
    "\n",
    "def budyko_point(df):\n",
    "    P = df[\"P mm/d\"].mean()\n",
    "    EP = df[\"EP mm/d\"].mean()\n",
    "    Q = df[\"Q mm/d\"].mean()\n",
    "    ET = P - Q\n",
    "    ET = max(0, min(ET, EP))\n",
    "\n",
    "    AI = EP / P\n",
    "    EI = ET / P\n",
    "    return P, EP, Q, ET, AI, EI\n",
    "P_pre, EP_pre, Q_pre, ET_pre, AI_pre, EI_pre = budyko_point(pre)\n",
    "P_post, EP_post, Q_post, ET_post, AI_post, EI_post = budyko_point(post)\n",
    "P_full, EP_full, Q_full, ET_full, AI_full, EI_full = budyko_point(full)\n",
    "\n",
    "phi = np.linspace(0.001, 5, 500)\n",
    "budyko = np.sqrt(phi * np.tanh(1/phi) * (1 - np.exp(-phi)))\n",
    "plt.figure(figsize=(10, 8))\n",
    "\n",
    "plt.plot(phi, budyko, color=\"black\", linewidth=2, label=\"Budyko curve\")\n",
    "\n",
    "phi_energy = np.linspace(0, 1, 200)\n",
    "plt.plot(phi_energy, phi_energy, 'k--', label='Energy limit')\n",
    "phi_water = np.linspace(1, 5, 200)\n",
    "plt.hlines(1, 1, 5, linestyles='--', color = 'black', label='Water limit')\n",
    "\n",
    "plt.scatter(AI_pre, EI_pre, color='#006633', s=140, edgecolor=\"black\",\n",
    "            label=\"Pre-deforestation mean\", zorder=5)\n",
    "plt.scatter(AI_post, EI_post, color='#a31010', s=140, edgecolor=\"black\",\n",
    "            label=\"Post-deforestation mean\", zorder=5)\n",
    "plt.scatter(AI_full, EI_full, color=\"blue\", s=140, edgecolor=\"black\",\n",
    "            label=\"Whole-period mean\", zorder=5)\n",
    "\n",
    "plt.text(AI_pre + 0.05, EI_pre, \"Pre\", color=\"green\", weight=\"bold\")\n",
    "plt.text(AI_post + 0.05, EI_post, \"Post\", color=\"red\", weight=\"bold\")\n",
    "plt.text(AI_full + 0.05, EI_full, \"Full\", color=\"blue\", weight=\"bold\")\n",
    "plt.xlim(0, 5)\n",
    "plt.ylim(0, 1.2)\n",
    "plt.xlabel(\"Aridity index φ = Ep / P\")\n",
    "plt.ylabel(\"Evaporative index Ea / P\")\n",
    "plt.title(\"Budyko Framework - Manning Catchment\")\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.legend(fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
